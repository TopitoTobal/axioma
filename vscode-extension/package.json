{
  "name": "axioma-lang",
  "displayName": "Axioma",
  "version": "1.0.0",
  "publisher": "TopitoTobal",
  "description": "Soporte para el lenguaje de programacion Axioma - programacion en espanol",
  "icon": "icons/axioma-icon.png",
  "license": "MIT",
  "homepage": "https://github.com/TopitoTobal/axioma",
  "repository": {
    "type": "git",
    "url": "https://github.com/TopitoTobal/axioma.git"
  },
  "bugs": {
    "url": "https://github.com/TopitoTobal/axioma/issues"
  },
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "axioma",
        "aliases": ["Axioma", "axioma"],
        "extensions": [".ax"],
        "configuration": "./language-configuration.json",
        "icon": {
          "dark": "./icons/axioma-icon.png",
          "light": "./icons/axioma-icon.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "axioma",
        "scopeName": "source.axioma",
        "path": "./syntaxes/axioma.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "axioma",
        "path": "./snippets/snippets.json"
      }
    ]
  }
}
